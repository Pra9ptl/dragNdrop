# CopilotKit runtime endpoint used by the frontend provider
VITE_COPILOT_RUNTIME_URL=http://localhost:4000/copilotkit

# Agent name exposed by your CopilotKit runtime
VITE_COPILOT_AGENT=canvasiq-assistant

# Optional: only needed for Copilot Cloud specific features
VITE_COPILOT_PUBLIC_API_KEY=

# Backend runtime settings
OPENAI_API_KEY=
COPILOT_BACKEND_PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
COPILOT_MODEL=gpt-4o-mini
